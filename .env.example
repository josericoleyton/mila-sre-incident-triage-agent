# =============================================================================
# Mila - AI Incident Management Pipeline
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# All services read configuration from this file via their config.py modules.

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# Model string for Pydantic AI (provider resolved from prefix)
# OpenRouter:   openrouter:google/gemma-4
# Anthropic:    anthropic:claude-sonnet-4-20250514
LLM_MODEL=openrouter:google/gemma-4

# Fallback model when primary is unavailable (circuit breaker)
LLM_FALLBACK_MODEL=openrouter:google/gemini-2.5-flash

# Circuit breaker tuning
FAILURE_THRESHOLD=2
COOLDOWN_SECONDS=60

# OpenRouter API key (required if LLM_MODEL starts with "openrouter:")
OPENROUTER_API_KEY=

# Anthropic API key (required if LLM_MODEL starts with "anthropic:")
ANTHROPIC_API_KEY=

# Confidence threshold for agent triage decisions (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Linear (Ticketing) Configuration
# -----------------------------------------------------------------------------
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Slack (Notifications) Configuration
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# -----------------------------------------------------------------------------
# GitHub (Code Analysis) Configuration
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Langfuse (LLM Observability) Configuration
# -----------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# -----------------------------------------------------------------------------
# Langfuse Internal (Database) Configuration
# -----------------------------------------------------------------------------
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@langfuse-db:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=02eff21f-66ca-466d-a39b-4158fd77f7d9
LANGFUSE_NEXTAUTH_URL=http://langfuse:3000
LANGFUSE_SALT=e208de5c-9c86-434d-a72b-6ed5275751d4

NGROK_AUTHTOKEN=